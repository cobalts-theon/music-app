rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    match /{document=**} {
      allow read, write: if true;
    }

    //1. Dữ liệu công khai: Mọi người đều có thể xem (Read), nhưng không ai được sửa (Write) trừ Admin
    match /songs/{songId} {
      allow read: if true;
      allow write: if false;
    }
    match /artists/{artistId} {
      allow read: if true;
      allow write: if false;
    }
    match /albums/{albumId} {
      allow read: if true;
      allow write: if false;
    }

    // 2. Dữ liệu cá nhân: Chỉ chủ sở hữu mới có quyền Xem và Sửa
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Playlist và Yêu thích của cá nhân
      match /favorites/{favId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}